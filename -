openapi: 3.0.3
info:
  title: CEMLAD Learning API
  version: 1.0.0
  description: "\n    # API REST para Gestión de Productos y Carritos\n    \n    Documentación\
    \ completa de endpoints y contrato de datos para consumir desde Frontend.\n  \
    \  \n    ## Características principales:\n    - Gestión de productos (CRUD)\n\
    \    - Carrito de compras\n    - Procesamiento de pagos (Efectivo/Tarjeta)\n \
    \   - Respuestas tipificadas con DTOs\n    "
  contact:
    name: CEMLAD API Support
    email: support@cemlad.com
  license:
    name: MIT
