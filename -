                  value:
                    error: Product not found
                  summary: Not Found
          description: Producto no encontrado
    patch:
      operationId: products_partial_update
      description: Obtiene los detalles de un producto específico por su ID.
      summary: Retrieve Product Details
      parameters:
      - in: path
        name: product_id
