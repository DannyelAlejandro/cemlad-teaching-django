  /carts:
    get:
      operationId: carts_retrieve
      description: Obtiene la lista completa de carritos o crea un nuevo carrito de
        compras.
      summary: List and Create Shopping Carts
      tags:
      - Carts
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Cart'
          description: Lista de todos los carritos disponibles
    post:
      operationId: carts_create
      description: |-
        List all carts or create a new cart.

        GET: Retrieve all shopping carts
        POST: Create a new shopping cart

        **Ejemplo Request (POST):**
        ```json
        {
            "customer_id": 100,
            "status": "ACT",
            "total": 0.0
        }
        ```
      tags:
      - Carts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CartCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CartCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CartCreate'
        required: true
      security:
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
              examples:
                Success:
                  value:
                    id: 1
                    customer_id: 100
                    status: ACT
                    total: 0.0
                    products: []
          description: Carrito creado exitosamente
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: Falló la creación del carrito
  /carts/{cart_id}:
    get:
      operationId: carts_retrieve_2
      description: Obtiene los detalles de un carrito específico incluyendo productos.
      summary: Retrieve Shopping Cart Details
      parameters:
      - in: path
        name: cart_id
        schema:
          type: integer
        description: ID único del carrito a recuperar
        required: true
      tags:
      - Carts
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
              examples:
                Success:
                  value:
                    id: 1
                    customer_id: 100
                    status: ACT
                    total: 2299.98
                    products:
                    - product_id: 1
                      product_name: Laptop
                      price: 999.99
                    - product_id: 2
                      product_name: Mouse
                      price: 29.99
          description: Detalles del carrito
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: Carrito no encontrado
  /carts/{cart_id}/pay:
    post:
      operationId: carts_pay_create
      description: Procesa el pago del carrito usando el método de pago especificado
        (Efectivo o Tarjeta).
      summary: Process Cart Payment
      parameters:
      - in: path
        name: cart_id
        schema:
          type: integer
        description: ID del carrito a pagar
        required: true
      tags:
      - Payments
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CartPay'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CartPay'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CartPay'
        required: true
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaymentResponse'
              examples:
                Success:
                  value:
                    message: Pago procesado exitosamente con CASH
          description: Pago procesado exitosamente
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                Error:
                  value:
                    error: Invalid payment method or cart not found
          description: Falló procesar el pago
  /carts/{cart_id}/products:
    post:
      operationId: carts_products_create
      description: Agrega un producto específico al carrito de compras indicado.
      summary: Add Product to Shopping Cart
      parameters:
      - in: path
        name: cart_id
        schema:
          type: integer
        description: ID del carrito
        required: true
      tags:
      - Carts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CartAddProduct'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CartAddProduct'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CartAddProduct'
        required: true
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
              examples:
                Success:
                  value:
                    id: 1
                    customer_id: 100
                    status: ACT
                    total: 1029.98
                    products:
                    - product_id: 1
                      product_name: Laptop
                      price: 999.99
                    - product_id: 2
                      product_name: Mouse
                      price: 29.99
          description: Carrito actualizado con el nuevo producto
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: Falló agregar el producto al carrito
  /carts/{cart_id}/products/{product_id}:
    delete:
      operationId: carts_products_destroy
      description: Elimina un producto específico del carrito de compras.
      summary: Remove Product from Shopping Cart
      parameters:
      - in: path
        name: cart_id
        schema:
          type: integer
        description: ID del carrito
        required: true
      - in: path
        name: product_id
        schema:
          type: integer
        description: ID del producto a eliminar
        required: true
      tags:
      - Carts
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
          description: Carrito actualizado sin el producto eliminado
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: Falló eliminar el producto del carrito
  /products:
    get:
      operationId: products_retrieve
      description: Obtiene la lista completa de productos o crea un nuevo producto.
      summary: List and Create Products
      tags:
      - Products
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/ProductResponse'
          description: Lista de todos los productos disponibles
    post:
      operationId: products_create
      description: |-
        List all products or create a new product.

        GET: Retrieve all products
        POST: Create a new product

        **Ejemplo Request (POST):**
        ```json
        {
            "name": "Laptop Dell XPS",
            "code": "SKU001",
            "price": 1299.99
        }
        ```
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Product'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Product'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Product'
        required: true
      security:
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
              examples:
                Success:
                  value:
                    id: 1
                    name: Laptop
                    code: SKU001
                    price: 999.99
          description: Producto creado exitosamente
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                Error:
                  value:
                    error: Failed to create product
          description: Falló la creación del producto
  /products/{product_id}:
    get:
      operationId: products_retrieve_2
      description: Obtiene los detalles de un producto específico por su ID.
      summary: Retrieve Product Details
      parameters:
      - in: path
        name: product_id
        schema:
          type: integer
        description: ID único del producto a recuperar
        required: true
      tags:
      - Products
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
              examples:
                Success:
                  value:
                    id: 1
                    name: Laptop
                    code: SKU001
                    price: 999.99
          description: Detalles del producto
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              examples:
                NotFound:
                  value:
                    error: Product not found
                  summary: Not Found
          description: Producto no encontrado
    put:
      operationId: products_update
      description: Obtiene los detalles de un producto específico por su ID.
      summary: Retrieve Product Details
      parameters:
      - in: path
        name: product_id
        schema:
          type: integer
        description: ID único del producto a recuperar
        required: true
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Product'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Product'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Product'
        required: true
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
              examples:
