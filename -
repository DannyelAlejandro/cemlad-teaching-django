components:
  schemas:
    Cart:
      type: object
      description: |-
        Serializer para carrito de compras.

        Representa un carrito con sus productos y estado.
      properties:
        id:
          type: integer
          readOnly: true
          description: ID único del carrito (auto-generado)
        customer_id:
          type: integer
          description: ID del cliente propietario del carrito
        status:
          type: string
          description: 'Estado del carrito: ACT (Activo), PAID (Pagado), CANC (Cancelado)'
          maxLength: 10
        total:
          type: number
          format: double
          description: Total del carrito (suma de todos los productos)
        products:
          type: array
          items:
            $ref: '#/components/schemas/Product'
          readOnly: true
          description: Lista de productos en el carrito
      required:
      - customer_id
      - id
      - products
      - status
      - total
    CartAddProduct:
      type: object
      description: Serializer para agregar un producto a un carrito.
      properties:
        product_id:
          type: integer
          description: ID del producto a agregar al carrito
      required:
      - product_id
    CartCreate:
      type: object
      description: Serializer para crear un nuevo carrito.
      properties:
        customer_id:
          type: integer
          description: ID del cliente propietario del carrito
        status:
          type: string
          default: ACT
          description: 'Estado inicial del carrito (por defecto: ACT)'
          maxLength: 10
        total:
          type: number
          format: double
          default: 0.0
          description: 'Total inicial del carrito (por defecto: 0.0)'
      required:
      - customer_id
    CartPay:
      type: object
      description: Serializer para procesar el pago de un carrito.
      properties:
        payment_method:
          allOf:
          - $ref: '#/components/schemas/PaymentMethodEnum'
          description: |-
            Método de pago: CASH (Efectivo) o CARD (Tarjeta)

            * `CASH` - CASH
            * `CARD` - CARD
      required:
      - payment_method
    ErrorResponse:
      type: object
      description: Respuesta estándar de error.
      properties:
        error:
          type: string
          description: Mensaje descriptivo del error
      required:
      - error
    PatchedProduct:
      type: object
      description: |-
        Serializer para productos del catálogo.

        Se utiliza tanto para listar productos como para crear nuevos.
      properties:
        id:
          type: integer
          readOnly: true
          description: ID único del producto (auto-generado)
        name:
          type: string
          description: Nombre del producto (máximo 255 caracteres)
          maxLength: 255
        code:
          type: string
          description: Código SKU único del producto (máximo 50 caracteres)
          maxLength: 50
        price:
          type: number
          format: double
          description: Precio unitario del producto en formato decimal
    PaymentMethodEnum:
      enum:
      - CASH
      - CARD
      type: string
      description: |-
        * `CASH` - CASH
        * `CARD` - CARD
    PaymentResponse:
      type: object
      description: Respuesta del procesamiento de pago.
      properties:
        message:
          type: string
          description: Mensaje con el resultado del pago
      required:
      - message
    Product:
      type: object
      description: |-
        Serializer para productos del catálogo.

        Se utiliza tanto para listar productos como para crear nuevos.
      properties:
        id:
          type: integer
          readOnly: true
          description: ID único del producto (auto-generado)
        name:
          type: string
          description: Nombre del producto (máximo 255 caracteres)
          maxLength: 255
        code:
          type: string
          description: Código SKU único del producto (máximo 50 caracteres)
          maxLength: 50
        price:
          type: number
          format: double
          description: Precio unitario del producto en formato decimal
      required:
      - code
      - id
      - name
      - price
    ProductResponse:
      type: object
      description: Respuesta de producto con todos los campos.
      properties:
        id:
          type: integer
          description: ID único del producto
        name:
          type: string
          description: Nombre del producto
        code:
          type: string
          description: Código SKU del producto
        price:
          type: number
          format: double
          description: Precio unitario
      required:
      - code
      - id
      - name
      - price
